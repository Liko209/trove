# Personal data — NEVER commit
data/
# sqlite-vec index DB lives here
models/
# bge-m3 / reranker GGUF weights (~870 MB; download on demand)
resources/bin/
# vendored llama.cpp binaries (~54 MB; run `npm run vendor:llama`)
.vendor-tmp/

# Per-user runtime artefacts
.cache/
.idea/
.vscode/
.DS_Store

# Locally-installed Agent Skills (vercel-labs `skills add` CLI).
# These live alongside the project but are per-developer and shouldn't
# leak into the repo or the packaged app.
.agents/
.claude/
skills-lock.json

# Build outputs
node_modules/
ui/node_modules/
electron/.dist/
dist-app/
dist-electron/
ui/dist/

# Swift bitrove-ocr build cache. Universal binary output is committed
# at release time to resources/bin/ (already ignored above).
swift/bitrove-ocr/.build/
swift/bitrove-ocr/.build-*/

# Test / temp
*.log

# Optional macOS app icon work
build/icon.icns.tmp
